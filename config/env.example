# Server (Unraid)
SERVER_HOST=192.168.1.200
DATA_SHARE=Misc
DATA_PATH=/mnt/user/Misc/imessage-backup
APP_PATH=/mnt/user/appdata/imessage-archive
SEARCH_PORT=8095

# Client (Mac) — copy to ~/.config/imessage-archive.env
UNRAID_HOST=192.168.1.200
UNRAID_SHARE=Misc
MOUNT_POINT=$HOME/mnt/unraid-imessage
LOCAL_EXPORT=$HOME/imessage-export
SERVER_URL=http://192.168.1.200:8095
SEARCH_API=http://192.168.1.200:8095
COPY_METHOD=full

# Immich — media storage (photos/videos/gifs → album "iMessage")
IMMICH_URL=http://192.168.1.200:8090
# API key is created in Immich UI (Profile → API Keys), NOT granted by this file.
# This file only stores the key string. Permissions are checkboxes on the key in Immich.
#
# Required permissions when creating/editing the key (Immich v2.5+ granular scopes):
#
# Mac upload script (client/upload-to-immich.py):
#   Assets → Upload          (asset.upload)
#   Albums → Read            (album.read) — find existing "iMessage" album
#   Albums → Create          (album.create) — if album does not exist yet
#   Album assets → Create    (albumAsset.create) — add uploads to the album
#
# Server thumbnail proxy (server/app/immich_client.py):
#   Assets → View            (asset.view) — thumbnails, preview, video playback
#   Assets → Download        (asset.download) — full-size original files
#
# asset.read is metadata/search only; it does NOT serve thumbnails or originals.
# Verify key: curl -H "x-api-key: YOUR_KEY" http://192.168.1.200:8090/api/api-keys/me
IMMICH_API_KEY=
IMMICH_ALBUM=iMessage

# Optional SMB credentials
# SMB_USER=
# SMB_PASS=

# Optional: display name for this Mac in the dashboard
# CLIENT_NAME=My MacBook
